* text=auto eol=crlf

# Text/source files — normalize to LF
*.html text eol=crlf
*.css  text eol=crlf
*.js   text eol=crlf
*.json text eol=crlf
*.md   text eol=crlf
*.gs   text eol=crlf

# Binary/media — never touch line endings
*.png  binary
*.jpg  binary
*.jpeg binary
*.JPG  binary
*.JPEG binary
*.gif  binary
*.webp binary
*.avif binary
*.ico  binary
*.svg  binary
*.mp4  binary
*.mov  binary
*.webm binary
*.pdf  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
